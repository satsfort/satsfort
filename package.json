{
    "name": "sats-fort-app",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e:build": "npm run build && cargo build --release --features custom-protocol --manifest-path src-tauri/Cargo.toml",
        "test:e2e": "npm run test:e2e:build && wdio run ./wdio.conf.ts",
        "test:e2e:mac": "bash scripts/test-e2e-docker.sh",
        "tauri": "tauri",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@tauri-apps/api": "^2",
        "@tauri-apps/plugin-http": "^2.5.8",
        "@tauri-apps/plugin-opener": "^2",
        "@types/bitcoinjs-lib": "^4.0.1",
        "bip32": "^5.0.1",
        "bitcoinjs-lib": "^7.0.1",
        "bs58check": "^4.0.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "tiny-secp256k1": "^2.2.4",
        "vite-plugin-top-level-await": "^1.6.0",
        "vite-plugin-wasm": "^3.6.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@tauri-apps/cli": "^2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/mocha": "^10.0.10",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^4.6.0",
        "@wdio/cli": "^8.46.0",
        "@wdio/local-runner": "^8.46.0",
        "@wdio/mocha-framework": "^8.46.0",
        "@wdio/spec-reporter": "^8.43.0",
        "better-sqlite3": "^12.9.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-sonarjs": "^4.0.3",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^7.0.4",
        "vitest": "^4.1.4",
        "webdriverio": "^8.46.0"
    }
}
